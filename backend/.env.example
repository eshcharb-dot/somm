# Somm Backend Configuration
# Copy to .env and fill in your API keys

# Claude API key (get at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Groq API key (free tier at console.groq.com)
GROQ_API_KEY=gsk_...

# Server port (default 3000)
PORT=3000

# Shared secret checked against the client's x-somm-token header. REQUIRED — the
# backend refuses every /api/ai request (fail closed) if this is unset. Keep this
# value in sync with SOMM_CLIENT_TOKEN in src/js/ai.js.
SOMM_TOKEN=somm-2025

# Upstash Redis REST credentials — REQUIRED in production/serverless (e.g. Vercel).
# Without these the backend can't durably enforce rate limits or daily token budgets
# across cold starts/instances, so it refuses requests (503) rather than silently
# under-enforcing. Not required for local dev (falls back to an in-memory limiter).
# Get a free database at upstash.com.
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Supabase project URL + anon key — optional. When set, the backend verifies a
# signed-in user's session JWT (sent by the client as Authorization: Bearer <token>)
# so abuse budgets can be scoped per-account instead of only per-IP. Same values as
# SUPABASE_URL/SUPABASE_KEY in src/js/auth.js.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
